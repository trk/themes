{
    "name": "Minimal",
    "slug": "minimal",
    "version": "1.0.0",
    "description": "Simple, distraction-free design for content-focused sites",
    "author": "Totoglu",
    "daisyui": {
        "preset": "lofi",
        "prefersDark": "nord"
    },
    "tags": ["starter", "minimal"],
    "supports": {
        "dark_mode": true,
        "theme_controller": false,
        "responsive": true,
        "animations": true
    },
    "screenshots": {
        "primary": null
    },
    "build": {
        "entries": [
            "resources/css/app.css",
            "resources/js/app.js"
        ]
    },
    "templates": {
        "example": {
            "label": "Example Template",
            "description": "A custom example template for this theme",
            "has_sidebar": false,
            "minimal_chrome": false
        }
    }
}
