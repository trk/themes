{
    "name": "TallDaisy",
    "slug": "talldaisy",
    "version": "1.0.0",
    "description": "Official T-CMS theme with daisyUI - supports all built-in presets with runtime theme switching",
    "author": "Totoglu",
    "daisyui": {
        "preset": "light",
        "prefersDark": "dark",
        "presets": "all"
    },
    "tags": ["starter", "multi-purpose"],
    "supports": {
        "dark_mode": true,
        "theme_controller": true,
        "responsive": true,
        "animations": true
    },
    "install": {
        "seed_data": "install/seed.json"
    },
    "build": {
        "css": "resources/css/app.css",
        "js": "resources/js/app.js",
        "output": "public"
    }
}
